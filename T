def start_camera():
    global cap, running, use_oak, oak_pipeline, oak_queue

    if running:
        return

    # ---------------- OAK FIRST ----------------
    try:
        import depthai as dai

        devices = dai.Device.getAllAvailableDevices()

        if len(devices) > 0:
            use_oak = True

            pipeline = dai.Pipeline()

            cam = pipeline.create(dai.node.ColorCamera)

            # 🔥 HIGH RES FOR AI (4K-ish)
            cam.setResolution(dai.ColorCameraProperties.SensorResolution.THE_4_K)

            cam.setColorOrder(dai.ColorCameraProperties.ColorOrder.BGR)
            cam.setInterleaved(False)

            xout = pipeline.create(dai.node.XLinkOut)
            xout.setStreamName("video")

            cam.video.link(xout.input)

            oak_pipeline = dai.Device(pipeline)

            oak_queue = oak_pipeline.getOutputQueue(
                name="video",
                maxSize=2,
                blocking=False
            )

            cap = None
            status_label.config(text="OAK Camera (4K) started")

            running = True
            update_frame()
            return

    except Exception as e:
        print("OAK failed, fallback USB:", e)

    # ---------------- USB FALLBACK ----------------
    use_oak = False

    cap = cv2.VideoCapture(0)

    if not cap.isOpened():
        messagebox.showerror("Error", "No camera found")
        return

    status_label.config(text="USB Camera started")

    running = True
    update_frame()
