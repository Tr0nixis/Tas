def select_camera():

    win = tk.Toplevel(root)
    win.title("Select Camera")
    win.geometry("300x200")

    tk.Label(
        win,
        text="Enter camera index (0, 1, 2...)",
        font=("Arial", 12)
    ).pack(pady=10)

    entry = tk.Entry(win)
    entry.pack(pady=5)

    def start_selected():

        global cap, running

        try:
            index = int(entry.get())
        except:
            messagebox.showerror("Error", "Invalid camera index")
            return

        cap = cv2.VideoCapture(index)

        if not cap.isOpened():
            messagebox.showerror("Error", f"Camera {index} not found")
            return

        running = True
        status_label.config(text=f"Camera {index} started")

        win.destroy()
        update_frame()

    tk.Button(
        win,
        text="Start Camera",
        command=start_selected
    ).pack(pady=10)
