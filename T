def list_cameras(max_test=10):

    available = []

    for i in range(max_test):

        cap_test = cv2.VideoCapture(i, cv2.CAP_DSHOW)  # better on Windows

        if cap_test is not None and cap_test.isOpened():

            ret, _ = cap_test.read()

            if ret:
                available.append(i)

        cap_test.release()

    return available
