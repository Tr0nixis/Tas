def build_heatmap(frame, patches, anomaly_memory):

    if len(anomaly_memory) == 0:
        return None

    h, w, _ = frame.shape

    if len(patches) == 0:
        return None

    scores = []

    for p in patches:
        sim = cosine_similarity([p], anomaly_memory)[0]
        scores.append(1.0 - np.max(sim))

    if len(scores) < 4:
        return None  # not enough data for grid

    side = int(np.sqrt(len(scores)))

    if side < 2:
        return None

    usable = side * side
    scores = scores[:usable]

    heat = np.array(scores).reshape(side, side)

    heat = cv2.resize(heat, (w, h))

    heat = heat / (heat.max() + 1e-6)
    heat = (heat * 255).astype(np.uint8)

    return cv2.applyColorMap(heat, cv2.COLORMAP_JET)
