def open_scans_folder():
    import subprocess
    import os

    path = os.path.abspath(SCAN_DIR)

    try:
        if os.name == "nt":
            os.startfile(path)
        elif os.name == "posix":
            subprocess.Popen(["xdg-open", path])
        else:
            messagebox.showinfo("Info", f"Scan folder: {path}")
    except Exception as e:
        messagebox.showerror("Error", str(e))
