def start_camera():

    global cap
    global running

    if running:
        return

    cap = cv2.VideoCapture(CAMERA_INDEX)

    if not cap.isOpened():

        messagebox.showerror(
            "Error",
            f"Camera {CAMERA_INDEX} not found"
        )

        return

    ret, frame = cap.read()

    if not ret:

        cap.release()

        messagebox.showerror(
            "Error",
            f"Camera {CAMERA_INDEX} opened but returned no image"
        )

        return

    running = True

    status_label.config(
        text=f"Camera {CAMERA_INDEX} started"
    )

    update_frame()
