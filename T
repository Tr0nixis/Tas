def update_frame():
    global running

    if not running or cap is None:
        return

    ret, frame = cap.read()

    if not ret:
        root.after(10, update_frame)
        return

    frame = cv2.flip(frame, 1)

    # FULL camera frame for AI
    ai_frame = frame.copy()

    # UI preview (300x300)
    display = cv2.resize(frame, (300, 300))
