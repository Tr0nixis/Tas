def start_camera():

    global cap
    global running

    if running:
        return

    found = False

    for index in range(10):

        test_cap = cv2.VideoCapture(index)

        if test_cap.isOpened():

            ret, frame = test_cap.read()

            if ret:

                print(f"Found camera {index}")

                cap = test_cap
                found = True

                status_label.config(
                    text=f"Camera {index} started"
                )

                break

            test_cap.release()

    if not found:

        messagebox.showerror(
            "Error",
            "No camera found"
        )

        return

    running = True
    update_frame()
