def list_cameras():
    cams = []

    import cv2
    for i in range(10):
        test = cv2.VideoCapture(i)
        if test.isOpened():
            cams.append(("OpenCV", i))
        test.release()

    try:
        import depthai as dai
        devices = dai.Device.getAllAvailableDevices()

        if len(devices) > 0:
            cams.append(("OAK", 0))
    except:
        pass

    return cams
