cam_node = oak_pipeline.create(dai.node.Camera).build()

# FULL RES (for processing)
full_res = cam_node.requestOutput((4056, 3040), type=dai.ImgFrame.Type.BGR888i)
full_queue = full_res.createOutputQueue(maxSize=2, blocking=False)

# PREVIEW (for UI ONLY)
preview = cam_node.requestOutput((1280, 720), type=dai.ImgFrame.Type.BGR888i)
preview_queue = preview.createOutputQueue(maxSize=2, blocking=False)

oak_pipeline.start()
