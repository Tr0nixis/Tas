def start_camera():

    global cap
    global running

    if running:
        return

    camera_index = simpledialog.askinteger(
        "Camera",
        "Enter camera index (0, 1, 2, etc):",
        initialvalue=0
    )

    if camera_index is None:
        return

    cap = cv2.VideoCapture(camera_index)

    if not cap.isOpened():

        messagebox.showerror(
            "Error",
            f"Camera {camera_index} not found"
        )

        return

    running = True

    status_label.config(
        text=f"Camera {camera_index} started"
    )

    update_frame()
