def select_camera():
    global selected_camera

    available = []

    # USB cameras
    for i in range(10):
        test = cv2.VideoCapture(i)
        if test.isOpened():
            available.append(("USB", i))
        test.release()

    # OAK cameras
    try:
        import depthai as dai
        devices = dai.Device.getAllAvailableDevices()

        for idx, d in enumerate(devices):
            available.append(("OAK", idx))
    except:
        pass

    if not available:
        messagebox.showerror("Error", "No cameras found")
        return

    text = "\n".join([f"{i}: {cam[0]}-{cam[1]}" for i, cam in enumerate(available)])

    choice = simpledialog.askinteger(
        "Select Camera",
        f"Available cameras:\n\n{text}\n\nEnter number:",
        minvalue=0,
        maxvalue=len(available) - 1
    )

    if choice is None:
        return

    selected_camera = available[choice]

    status_label.config(text=f"Selected: {selected_camera[0]}-{selected_camera[1]}")
