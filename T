if cam[0] == "OAK":
    import depthai as dai

    use_oak = True

    oak_pipeline = dai.Pipeline()

    cam_node = oak_pipeline.create(dai.node.Camera)

    # FULL RES (AI STREAM)
    full_out = cam_node.requestOutput(
        (4056, 3040),
        type=dai.ImgFrame.Type.BGR8888
    )

    oak_full_queue = full_out.createOutputQueue(maxsize=2, blocking=False)

    # PREVIEW STREAM (UI ONLY)
    preview_out = cam_node.requestOutput(
        (1280, 960),
        type=dai.ImgFrame.Type.BGR8888
    )

    oak_preview_queue = preview_out.createOutputQueue(maxsize=2, blocking=False)

    oak_pipeline.start()
    status_label.config(text="OAK camera selected")
