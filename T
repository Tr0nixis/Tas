if cam[0] == "OAK":
    import depthai as dai

    use_oak = True
    oak_pipeline = dai.Pipeline()

    cam_node = oak_pipeline.create(dai.node.ColorCamera)

    # FULL (AI)
    cam_node.setPreviewSize(4056, 3040)
    cam_node.setInterleaved(False)

    xout_full = oak_pipeline.create(dai.node.XLinkOut)
    xout_full.setStreamName("full")

    cam_node.preview.link(xout_full.input)

    # PREVIEW (UI)
    cam_node.setPreviewSize(1280, 960)

    xout_preview = oak_pipeline.create(dai.node.XLinkOut)
    xout_preview.setStreamName("preview")

    cam_node.preview.link(xout_preview.input)

    device = dai.Device(oak_pipeline)

    oak_full_queue = device.getOutputQueue("full", maxSize=2, blocking=False)
    oak_preview_queue = device.getOutputQueue("preview", maxSize=2, blocking=False)

    status_label.config(text="OAK camera selected")
