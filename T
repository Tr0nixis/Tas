def select_camera():
    global camera_type, camera_id

    import cv2
    import depthai as dai

    available = []

    # USB cameras
    for i in range(10):
        test = cv2.VideoCapture(i)
        if test.isOpened():
            available.append(("USB", f"USB-{i}", i))
        test.release()

    # OAK cameras
    try:
        devices = dai.Device.getAllAvailableDevices()
        for idx, dev in enumerate(devices):
            name = getattr(dev, "name", f"OAK-{idx+1}")
            available.append(("OAK", name, dev))
    except:
        pass

    if not available:
        messagebox.showerror("Error", "No cameras found")
        return

    menu = "Select camera:\n\n"
    for i, cam in enumerate(available):
        menu += f"{i}: {cam[1]}\n"

    choice = simpledialog.askinteger(
        "Camera Select",
        menu,
        minvalue=0,
        maxvalue=len(available)-1
    )

    if choice is None:
        return

    camera_type, _, camera_id = available[choice]

    status_label.config(text=f"Selected: {camera_type}")
