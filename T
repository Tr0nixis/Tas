def start_camera():
    global cap, running

    if running:
        return

    available = []

    import cv2
    for i in range(10):
        test = cv2.VideoCapture(i)
        if test.isOpened():
            available.append(i)
        test.release()

    if not available:
        messagebox.showerror("Error", "No cameras found")
        return

    cam = simpledialog.askinteger(
        "Camera",
        f"Available: {available}\nPick one:",
        initialvalue=available[0]
    )

    if cam is None:
        return

    cap = cv2.VideoCapture(cam)

    if not cap.isOpened():
        messagebox.showerror("Error", "Failed to open camera")
        return

    running = True
    status_label.config(text=f"Camera {cam} started")
    update_frame()
