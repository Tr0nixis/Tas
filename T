import depthai as dai

if cam[0] == "OAK":
    use_oak = True

    pipeline = dai.Pipeline()

    cam_node = pipeline.create(dai.node.Camera)

    # FULL RES output (AI / processing)
    full_out = cam_node.requestOutput(
        (4056, 3040),
        type=dai.ImgFrame.Type.BGR8888
    )

    full_queue = full_out.createOutputQueue(maxsize=2, blocking=False)

    # PREVIEW output (UI only, lower res)
    preview_out = cam_node.requestOutput(
        (1280, 960),
        type=dai.ImgFrame.Type.BGR8888
    )

    preview_queue = preview_out.createOutputQueue(maxsize=2, blocking=False)

    pipeline.start()

    status_label.config(text="OAK camera selected")
