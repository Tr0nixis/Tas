if bbox is not None:

    x1, y1, x2, y2 = bbox

    cam_h, cam_w = frame.shape[:2]
    disp_h, disp_w = display.shape[:2]

    sx = disp_w / cam_w
    sy = disp_h / cam_h

    dx1 = int(x1 * sx)
    dy1 = int(y1 * sy)
    dx2 = int(x2 * sx)
    dy2 = int(y2 * sy)

    cv2.rectangle(
        display,
        (dx1, dy1),
        (dx2, dy2),
        (255,255,0),
        2
    )
