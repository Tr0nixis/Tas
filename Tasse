import cv2
import json
import os
from datetime import datetime

# settings

camera_index=0
black_threshold=40
min_defect_area=1000

# folders and files

log_file="defective_log.json"
image_folder="defective_products"

os.makedirs(image_folder,exist_ok=True)

if not os.path.exists(log_file):
    with open(log_file,"w") as f:
        json.dump([],f)

# qr detector

qr_detector=cv2.QRCodeDetector()

def get_qr_code(frame):
    data,points,_=qr_detector.detectAndDecode(frame)

    if points is not None and data:
        return data.strip()

    return None

# defect detection

def is_defective(frame):
    gray=cv2.cvtColor(frame,cv2.COLOR_BGR2GRAY)

    _,thresh=cv2.threshold(
        gray,
        black_threshold,
        255,
        cv2.THRESH_BINARY_INV
    )

    contours,_=cv2.findContours(
        thresh,
        cv2.RETR_EXTERNAL,
        cv2.CHAIN_APPROX_SIMPLE
    )

    largest_area=0

    for contour in contours:
        area=cv2.contourArea(contour)

        if area>largest_area:
            largest_area=area

    return largest_area>=min_defect_area,largest_area

# logging

def save_defect(product_id,image_name,area):
    try:
        with open(log_file,"r") as f:
            logs=json.load(f)
    except:
        logs=[]

    logs.append({
        "timestamp":datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
        "product_id":product_id,
        "status":"DEFECTIVE",
        "defect_area":area,
        "image":image_name
    })

    with open(log_file,"w") as f:
        json.dump(logs,f,indent=4)

# camera

cap=cv2.VideoCapture(camera_index)

if not cap.isOpened():
    print("could not open camera")
    quit()

status_text="waiting..."

while True:
    ret,frame=cap.read()

    if not ret:
        continue

    display_frame=frame.copy()

    cv2.putText(
        display_frame,
        status_text,
        (20,40),
        cv2.FONT_HERSHEY_SIMPLEX,
        1,
        (0,255,0),
        2
    )

    cv2.imshow("product inspection",display_frame)

    key=cv2.waitKey(1)&0xFF

    # q quits

    if key==ord("q"):
        break

    # space captures and inspects

    if key==32:

        qr_id=get_qr_code(frame)

        if qr_id is None:
            status_text="no qr found"
            print("no qr code detected")
            continue

        defective,area=is_defective(frame)

        if defective:

            timestamp=datetime.now().strftime("%Y%m%d_%H%M%S")

            image_name=f"{qr_id}_{timestamp}.jpg"
            image_path=os.path.join(image_folder,image_name)

            cv2.imwrite(image_path,frame)

            save_defect(
                qr_id,
                image_name,
                area
            )

            status_text=f"defective: {qr_id}"

            print()
            print("defective product found")
            print("product id:",qr_id)
            print("saved image:",image_path)

        else:

            status_text=f"good: {qr_id}"

            print()
            print("good product")
            print("product id:",qr_id)

cap.release()
cv2.destroyAllWindows()
